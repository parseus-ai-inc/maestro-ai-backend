# Maestro AI — backend (n8n) environment
# Copy this file to ".env" and fill in your values.
# NEVER commit the filled-in .env — it is in .gitignore.

# --- n8n login (CHANGE THESE) ------------------------------------
# Username for the n8n editor at http://localhost:5678
N8N_BASIC_AUTH_USER=admin
# Pick a strong password. Docker will refuse to start if this is blank.
N8N_BASIC_AUTH_PASSWORD=change-me-to-a-strong-password

# --- Google Drive --------------------------------------------------
# The Drive folder where the pipeline creates per-job output folders.
# Create a folder in Drive, share it with your service account (Editor),
# and copy the ID from the folder's URL.
ROOT_FOLDER_ID=your-google-drive-folder-id

# --- Misc ----------------------------------------------------------
# IANA timezone for n8n.
GENERIC_TIMEZONE=America/Los_Angeles

# Optional: pin the compose project name so you don't need -p each time.
# COMPOSE_PROJECT_NAME=maestro-ai
