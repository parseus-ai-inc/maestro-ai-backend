    {
      "parameters": {
        "jsCode": "const all = $input.all().map(i => i.json);\n\nconst failures = all.filter(x => x?._type === 'failure');\nconst usage = all.filter(x => x?._type === 'usage');\nconst rawJobs = all.filter(x => x?._type === 'job');\n\n// Strip _type from jobs; downstream nodes don't need it\nconst jobs = rawJobs.map(({ _type, ...rest }) => rest);\n\nconst bySource = jobs.reduce((acc, j) => {\n  const s = j.source || 'unknown';\n  acc[s] = (acc[s] || 0) + 1;\n  return acc;\n}, {});\n\nconsole.log(`[Job Fetcher] ${jobs.length} jobs, ${failures.length} failures, ${usage.length} usage`);\n\nreturn [{\n  json: {\n    jobs: jobs,\n    failures: failures,\n    usage: usage,\n    stats: {\n      total: jobs.length,\n      per_source: bySource,\n      failures_count: failures.length\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
