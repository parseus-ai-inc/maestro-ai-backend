      "name": "Job Ranker"
    },
    {
      "parameters": {
        "jsCode": "// Prepare Recorder Input â€” single source of truth for both recorders.\n// Emits ONE item containing the exact shapes both recorders need.\n//\n// FAT-FIELD REJOIN: the jobs flowing through the rankerâ†’scorer path are slimmed\n// (company/title/location/remote + scores), so url/source/posted_at/description_html\n// are lost by the time they reach here. We rejoin those fat fields from Job Post\n// Processing's full output, keyed on company+title+location (job_id doesn't exist\n// yet â€” it's minted in Build Discovery Row).\n\nconst items = $input.all();\nconst first = items[0]?.json || {};\nconst onTrueBranch = !!first.score;\n\n// Build a lookup of fat jobs from Job Post Processing.\nconst fatJobs = $('Job Post Processing').all().map(i => i.json);\nconst fatKey = (j) => [\n  String(j?.company || '').toLowerCase().trim(),\n  String(j?.title || '').toLowerCase().trim(),\n  String(j?.location || '').toLowerCase().trim()\n].join('||');\nconst fatById = new Map();\nfor (const fj of fatJobs) fatById.set(fatKey(fj), fj);\n\nconst FAT_FIELDS = ['url', 'source', 'posted_at', 'description_html', 'description', 'salary_text', 'employment_type'];\nconst rejoin = (slimJob) => {\n  const fat = fatById.get(fatKey(slimJob));\n  if (!fat) return slimJob;\n  const merged = { ...slimJob };\n  for (const f of FAT_FIELDS) {\n    if (merged[f] === undefined || merged[f] === null || merged[f] === '') {\n      if (fat[f] !== undefined) merged[f] = fat[f];\n    }\n  }\n  return merged;\n};\n\nlet scored_jobs;\nlet agent_10_usage;\nif (onTrueBranch) {\n  // Each item: { run_id, job, score, ... }. Rejoin fat fields into job.\n  scored_jobs = items.map(i => ({ ...i.json, job: rejoin(i.json.job || {}) }));\n  agent_10_usage = first.agent_10_usage || null;\n} else {\n  scored_jobs = [];\n  agent_10_usage = first.usage || null;\n}\n\nconst run_id      = $('Data Loader').first().json.run_id      || '';\nconst database_id = $('Data Loader').first().json.database_id || '';\nconst failures    = $('Job Fetcher').first().json.failures    || [];\nconst usage       = $('Job Fetcher').first().json.usage       || [];\nconst count       = Number($('Job Ranker').first().json.count ?? 0);\n\nconsole.log(`[Prepare Recorder Input] branch=${onTrueBranch ? 'TRUE' : 'FALSE'}, count=${count}, scored_jobs=${scored_jobs.length}, fat_lookup=${fatById.size}, failures=${failures.length}`);\n\nreturn [{\n  json: {\n    run_id,\n    database_id,\n    scored_jobs,\n    count,\n    failures,\n    usage,\n    job_result: {\n      scored_jobs,\n      agent_10_usage,\n      run_id\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
