      "name": "Job Discovery Recorder"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const score = $input.item.json;\nconst job = $('Split Jobs').item.json;\nconst runId = $('Data Loader').first().json.run_id || '';\nconst pricing = $('Data Loader').first().json.pricing || {};\nconst computeCost = (usage, rates) => {\n  if (!rates) return 0;\n  return (usage.input_tokens || 0) / 1e6 * (rates.input_per_million || 0) +\n         (usage.output_tokens || 0) / 1e6 * (rates.output_per_million || 0) +\n         (usage.cached_input_tokens || 0) / 1e6 * (rates.cached_input_per_million || 0) +\n         (usage.cache_write_tokens || 0) / 1e6 * (rates.cache_write_per_million || 0);\n};\nconst modelUsed = score.model_used || 'unknown';\nconst rates = pricing[modelUsed] || null;\nif (!rates) {\n  console.log(`[Log Job Result] WARNING: no pricing for model \"${modelUsed}\". Cost will be 0.`);\n}\nconst usage = {\n  input_tokens: score.tokens?.input || 0,\n  output_tokens: score.tokens?.output || 0,\n  cached_input_tokens: score.cached_input_tokens || 0,\n  cache_write_tokens: score.cache_write_tokens || 0\n};\nconst cost = computeCost(usage, rates);\n\n// Agent 10 (Job Ranker) usage â€” sourced from Summarize via Job Ranker's first\n// item. Same value carried on every emitted Log Job Result item; Prepare\n// Recorder Input picks it up once (one row per run). Cost is already computed\n// by Agent 10's Summarize so we pass the object through verbatim.\nconst a10 = $('Job Ranker').first().json.usage || null;\n\nconsole.log(`[Log Job Result] [${job.company}] ${job.title}: target=${score.overall_score}/${score.verdict}, background=${score.background_overall_score}/${score.background_verdict}, $${cost.toFixed(6)}, tokens=${usage.input_tokens}+${usage.output_tokens}, agent_10_usage=${a10 ? `${a10.model_used} ${a10.tokens?.input}in/${a10.tokens?.output}out` : 'null'}`);\n// Credit detection: did this job's scorer fail specifically on insufficient_credit?\n// (Agent 8 propagates Call LLM's error.category, including 'insufficient_credit'.)\nconst creditEvent = score.success === false && score.error?.category === 'insufficient_credit';\nreturn {\n  json: {\n    run_id: runId,\n    job: job,\n    score: {\n      overall_score: score.overall_score,\n      background_overall_score: score.background_overall_score,\n      verdict: score.verdict,\n      background_verdict: score.background_verdict,\n      dimensions: score.dimensions,\n      restrictions: score.restrictions,\n      strengths: score.strengths,\n      gaps: score.gaps,\n      rationale: score.rationale\n    },\n    credit_event: creditEvent,\n    tokens: { input: usage.input_tokens, output: usage.output_tokens },\n    cached_input_tokens: usage.cached_input_tokens,\n    cache_write_tokens: usage.cache_write_tokens,\n    cost: cost,\n    model_used: modelUsed,\n    provider_used: score.provider_used || 'unknown',\n    scored_at: new Date().toISOString(),\n    agent_10_usage: a10\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
