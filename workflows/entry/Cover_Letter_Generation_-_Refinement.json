    {
      "parameters": {
        "jsCode": "// Build Response â€” cover letter generate/refine. Reads the result from Log Job Result.\nconst jr = $('Log Job Result').first().json;\nconst verifier = jr.cover_verifier || {};\nconst row = jr.cover_letter_row || {};\nconst jobId = jr.job?.job_id || '';\nconst version = Number(row.version) || 1;\n\nconst ok = jr.processed_status === 'done';\n\nreturn [{\n  json: {\n    ok,\n    mode: jr.mode,                                   // 'generate' | 'refine'\n    cover_letter_id: `${jobId}_v${version}`,\n    version,\n    source: row.source || (jr.mode === 'refine' ? 'refinement' : 'original'),\n    cover_letter_markdown: jr.cover_letter?.markdown || '',\n    verifier_ran: verifier.ran || false,\n    verifier_verdict: verifier.ran ? (verifier.verdict || null) : null,\n    unsupported_count: (verifier.ran && typeof verifier.unsupported_count === 'number') ? verifier.unsupported_count : null,\n    cost_usd: (typeof jr.cover_cost === 'number') ? jr.cover_cost : 0,\n    error: ok ? null : (jr.error_log || []).join('; ')\n  }\n}];"
      },
