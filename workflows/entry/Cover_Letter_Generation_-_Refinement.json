      "name": "Cover Letter Refiner"
    },
    {
      "parameters": {
        "jsCode": "// Normalize Build Output â€” converges the generate (Agent 2) and refine (Agent 11)\n// branches into one uniform envelope, so the verifier / Log Job Result / recorder\n// read a single shape regardless of which branch ran.\n// Reads ONLY its own input (the executed branch's output) â€” never references the\n// sibling branch node by name (which would throw, as it didn't execute).\nconst input = $input.first().json;\nconst mode = $('Set Inputs').first().json.mode;\n\nlet coverLetterMarkdown = '';\nlet buildSuccess = false;\nlet buildError = null;\nlet sourceAgent = '';\nlet tokens = { input: 0, output: 0 };\nlet cachedInputTokens = 0;\nlet cacheWriteTokens = 0;\nlet modelUsed = 'unknown';\nlet providerUsed = 'unknown';\n\nif (mode === 'generate') {\n  // Agent 2 (Cover Letter Builder) shape: { success, result: { cover_letter_markdown }, tokens, ... }\n  sourceAgent = 'agent_2';\n  buildSuccess = input.success === true;\n  coverLetterMarkdown = input.result?.cover_letter_markdown || '';\n  buildError = input.success === false ? Object.assign({}, input.error || {}, { source_agent: 'agent_2' }) : null;\n  tokens = input.tokens || { input: 0, output: 0 };\n  cachedInputTokens = input.cached_input_tokens || 0;\n  cacheWriteTokens = input.cache_write_tokens || 0;\n  modelUsed = input.model_used || 'unknown';\n  providerUsed = input.provider_used || 'unknown';\n} else {\n  // Agent 11 (Cover Letter Refiner) shape: { success, cover_letter_markdown, tokens, ... }\n  sourceAgent = 'agent_11';\n  buildSuccess = input.success === true;\n  coverLetterMarkdown = input.cover_letter_markdown || '';\n  buildError = input.success === false ? Object.assign({}, input.error || {}, { source_agent: 'agent_11' }) : null;\n  tokens = input.tokens || { input: 0, output: 0 };\n  cachedInputTokens = input.cached_input_tokens || 0;\n  cacheWriteTokens = input.cache_write_tokens || 0;\n  modelUsed = input.model_used || 'unknown';\n  providerUsed = input.provider_used || 'unknown';\n}\n\nconsole.log(`[Normalize Build Output] mode=${mode} source=${sourceAgent} success=${buildSuccess} chars=${coverLetterMarkdown.length}`);\n\nreturn [{\n  json: {\n    cover_letter_markdown: coverLetterMarkdown,\n    build_success: buildSuccess,\n    build_error: buildError,\n    source_agent: sourceAgent,\n    tokens,\n    cached_input_tokens: cachedInputTokens,\n    cache_write_tokens: cacheWriteTokens,\n    model_used: modelUsed,\n    provider_used: providerUsed\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        64,
        -448
      ],
      "id": "4c6d9408-2e4b-480a-8989-a9df348f6000",
      "name": "Normalize Build Output"
    }
