    {
      "parameters": {
        "jsCode": "// Set Inputs â€” Cover Letter Generation / Refinement webhook entry.\n// Parses + validates the dashboard's request. Two modes:\n//   generate â†’ no cover letter exists yet; build v1 from master doc + JD (Agent 2)\n//   refine   â†’ cover letter exists; revise it per user instructions (Agent 11)\n// Cover letters are written from MASTER DOC + JD only (never the resume).\n// Provider/model/max_tokens are config-only (config.*_cover_letter_drafter / _refiner),\n// resolved inside Agents 2/11; the dashboard shows them read-only.\n\nconst body = $input.first().json.body || $input.first().json || {};\n\nconst mode = String(body.mode || 'refine').toLowerCase().trim();\n\nconst req = {\n  mode,\n  application_run_id: String(body.application_run_id || '').trim(),\n  run_verifier: body.run_verifier !== false,   // default ON\n  // Job context (sent by dashboard so no jobs-sheet read):\n  job_id: String(body.job_id || '').trim(),\n  url: String(body.url || '').trim(),\n  company: String(body.company || '').trim(),\n  title: String(body.title || '').trim(),\n  location: String(body.location || '').trim(),\n  jd_text: String(body.jd_text || body.description_html || body.jd_summary || ''),\n  // Refine-only: the parent cover letter being revised.\n  parent_cover_letter_id: String(body.parent_cover_letter_id || '').trim(),\n  parent_cover_letter_markdown: String(body.parent_cover_letter_markdown || ''),\n  refinement_instructions: String(body.refinement_instructions || '').trim(),\n  parent_version: Number(body.parent_version) || 0,\n  parent_ran_verifier: body.parent_ran_verifier === true || String(body.parent_ran_verifier).toLowerCase().trim() === 'true',\n  verifier_output: body.verifier_output || null\n};\n\n// Mode-aware validation â€” fail loud so the webhook returns a clear error.\nconst missing = [];\nif (!req.job_id) missing.push('job_id');\nif (!req.jd_text) missing.push('jd_text');\n\nif (req.mode === 'generate') {\n  // First cover letter on-demand: built from master doc + JD. No parent, version 1.\n  // Nothing else required beyond job context + jd_text.\n} else if (req.mode === 'refine') {\n  if (!req.parent_cover_letter_id) missing.push('parent_cover_letter_id');\n  if (!req.parent_cover_letter_markdown) missing.push('parent_cover_letter_markdown');\n  if (!req.refinement_instructions) missing.push('refinement_instructions');\n  // Parent's verifier_output required only if the parent pass ran verifier.\n  if (req.parent_ran_verifier && !req.verifier_output) {\n    missing.push('verifier_output (required for refine when parent pass ran verifier)');\n  }\n} else {\n  throw new Error(`[Cover Set Inputs] Unknown mode '${req.mode}' â€” expected 'generate' or 'refine'`);\n}\n\nif (missing.length) {\n  throw new Error(`[Cover Set Inputs] Missing required field(s): ${missing.join(', ')}`);\n}\n\n// Derive version + source + parent for the recorder.\nconst version = req.mode === 'refine' ? (req.parent_version + 1) : 1;\nconst source = req.mode === 'refine' ? 'refinement' : 'original';\nconst parent_cover_letter_id = req.mode === 'refine' ? req.parent_cover_letter_id : '';\n\nconsole.log(`[Cover Set Inputs] mode=${req.mode} job_id=${req.job_id} version=${version} source=${source} verifier=${req.run_verifier}`);\n\nreturn [{\n  json: {\n    ...req,\n    version,\n    source,\n    parent_cover_letter_id_resolved: parent_cover_letter_id\n  }\n}];"
      },
