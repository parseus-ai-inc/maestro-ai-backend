  "nodes": [
    {
      "parameters": {
        "jsCode": "// Log Job Result â€” Cover Letter Generation/Refinement workflow.\n// Assembles the result for: Model Usage Recorder, Cover Letter Recorder, and the webhook\n// response. One build agent ran (agent_2 generate / agent_11 refine) via Normalize Build\n// Output, plus optional verifier (agent_4). No scorer, no critic (resume-only agents).\n// Cost computed from tokens Ã— pricing.\n\nconst safeGet = (nodeName) => {\n  try { return $(nodeName)?.first()?.json ?? null; }\n  catch (err) { console.log(`[Cover Log] Node '${nodeName}' not found`); return null; }\n};\n\nconst req = $('Set Inputs').first().json;\nconst pricing = $('Data Loader').first().json.pricing || {};\nconst runId = $('Data Loader').first().json.run_id || '';   // cl_<execution.id>\nconst mode = req.mode;                                       // 'generate' | 'refine'\n\nconst computeCost = (sub, rates) => {\n  if (!rates || !sub) return 0;\n  return (sub.tokens?.input || 0) / 1e6 * (rates.input_per_million || 0) +\n         (sub.tokens?.output || 0) / 1e6 * (rates.output_per_million || 0) +\n         (sub.cached_input_tokens || 0) / 1e6 * (rates.cached_input_per_million || 0) +\n         (sub.cache_write_tokens || 0) / 1e6 * (rates.cache_write_per_million || 0);\n};\nconst missingPricing = new Set();\nconst costFor = (sub, agentId) => {\n  if (!sub) return 0;\n  const model = sub.model_used || '';\n  if (!model || model === 'skipped' || model === 'crash' || model === 'unknown') return 0;\n  const rates = pricing[model] || null;\n  if (!rates) { console.log(`[Cover Log] no pricing for \"${model}\" (${agentId})`); missingPricing.add(`${agentId}:${model}`); }\n  return computeCost(sub, rates);\n};\n\n// The build output is normalized (agent_2 generate / agent_11 refine) by Normalize Build Output.\nconst build = safeGet('Normalize Build Output') || {};\nconst buildAgentId = build.source_agent || (mode === 'generate' ? 'agent_2' : 'agent_11');\nconst verifierOut = safeGet('Cover Letter Verifier');   // null if verifier gate was false\n\nconst finalMarkdown = build.cover_letter_markdown || '';\n\n// Build a sub-object shaped like the agents for costing.\nconst buildSub = {\n  success: build.build_success,\n  tokens: build.tokens || { input: 0, output: 0 },\n  cached_input_tokens: build.cached_input_tokens || 0,\n  cache_write_tokens: build.cache_write_tokens || 0,\n  model_used: build.model_used || 'unknown',\n  provider_used: build.provider_used || 'unknown',\n  error: build.build_error || null\n};\n\nconst costBuild = costFor(buildSub, buildAgentId);\nconst costVerifier = costFor(verifierOut, 'agent_4');\n\nconst newVersion = (mode === 'refine') ? ((Number(req.parent_version) || 0) + 1) : 1;\n\n// error_log: original failures only (not cascaded).\nconst errorLog = [];\nif (buildSub.success === false && build.build_error?.cascaded !== true) {\n  errorLog.push(`${buildAgentId}:${build.build_error?.category || 'unknown'}`);\n}\nif (verifierOut && verifierOut.success === false && verifierOut.cascaded !== true) {\n  errorLog.push(`agent_4:${verifierOut.error?.category || 'unknown'}`);\n}\nfor (const entry of missingPricing) errorLog.push(`data_loader:missing_pricing:${entry}`);\n\nconst totalCost = costBuild + costVerifier;\nconst hasFailure = (buildSub.success === false) || (verifierOut && verifierOut.success === false);\n// Credit detection: did the build or verifier fail specifically on insufficient_credit?\nconst hasInsufficientCredit =\n  (buildSub.success === false && build.build_error?.cascaded !== true && build.build_error?.category === 'insufficient_credit') ||\n  (verifierOut && verifierOut.success === false && verifierOut.cascaded !== true && verifierOut.error?.category === 'insufficient_credit');\n\nconst result = {\n  run_id: runId,\n  mode,\n  application_run_id: req.application_run_id || '',\n  job: {\n    job_id: req.job_id || '',\n    company: req.company || '',\n    title: req.title || '',\n    url: req.url || ''\n  },\n\n  // Cover letter build sub (agent_2 generate / agent_11 refine). Carries the new letter.\n  cover_letter: {\n    ran: true,\n    success: buildSub.success || false,\n    source_agent: buildAgentId,\n    markdown: finalMarkdown,\n    tokens: buildSub.tokens,\n    cached_input_tokens: buildSub.cached_input_tokens,\n    cache_write_tokens: buildSub.cache_write_tokens,\n    cost: costBuild,\n    model_used: buildSub.model_used,\n    provider_used: buildSub.provider_used,\n    error: buildSub.error\n  },\n  cover_verifier: {\n    ran: !!verifierOut,\n    success: verifierOut?.success || false,\n    cascaded: verifierOut?.cascaded || false,\n    verdict: verifierOut?.result?.verdict || 'unknown',\n    unsupported_count: verifierOut?.result?.unsupported_count || 0,\n    issues: verifierOut?.result?.issues || [],\n    tokens: verifierOut?.tokens || { input: 0, output: 0 },\n    cached_input_tokens: verifierOut?.cached_input_tokens || 0,\n    cache_write_tokens: verifierOut?.cache_write_tokens || 0,\n    cost: costVerifier,\n    model_used: verifierOut?.model_used || 'unknown',\n    provider_used: verifierOut?.provider_used || 'unknown',\n    error: verifierOut?.error || null\n  },\n\n  // cover_letter_row: consumed by Cover Letter Recorder to write the cover_letters-tab row.\n  cover_letter_row: {\n    version: newVersion,\n    source: (mode === 'refine') ? 'refinement' : 'original',\n    parent_cover_letter_id: (mode === 'refine') ? (req.parent_cover_letter_id || '') : '',\n    refinement_instructions: (mode === 'refine') ? (req.refinement_instructions || '') : ''\n  },\n\n  cover_cost: Number(totalCost.toFixed(6)),\n  cover_tokens: {\n    input: (buildSub.tokens?.input || 0) + (verifierOut?.tokens?.input || 0),\n    output: (buildSub.tokens?.output || 0) + (verifierOut?.tokens?.output || 0)\n  },\n  error_log: errorLog,\n  processed_status: hasInsufficientCredit ? 'insufficient_credit' : (hasFailure ? 'error' : 'done'),\n  credit_event: hasInsufficientCredit,\n  generated_at: new Date().toISOString()\n};\n\nconsole.log(`[Cover Log] mode=${mode} run=${runId} job=${result.job.job_id} v${newVersion} source=${result.cover_letter_row.source} verifier=${result.cover_verifier.ran} cost=$${totalCost.toFixed(4)} status=${result.processed_status}`);\n\nreturn [{ json: result }];"
      },
