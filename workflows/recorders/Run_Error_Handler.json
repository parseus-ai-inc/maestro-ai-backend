    {
      "parameters": {
        "jsCode": "// Build Error Row â€” Run Error Handler\n// Mode: Run Once for All Items\n// Fires from Error Trigger when a parent workflow fails.\n// Reconstructs the same run_id format Data Loader uses (prefix + execution.id)\n// so this row joins with successful rows in jobs/agent_outputs/model_usage.\n\nconst input = $('Error Trigger').first()?.json || {};\nconst execution = input.execution || {};\nconst workflow = input.workflow || {};\nconst errObj = execution.error || {};\n\n// Prefix mapping matches Data Loader's modeâ†’prefix logic, keyed by orchestrator\n// workflow name (each orchestrator runs exactly one Data Loader mode).\nconst prefixMap = {\n  'Job Discovery': 'disc_',\n  'Application Orchestrator': 'app_',\n  'Application Refinement': 'refine_',\n  'Cover Letter Generation & Refinement': 'cl_'\n};\nconst prefix = prefixMap[workflow.name] || 'unknown_';\nconst executionId = execution.id || '';\nconst runId = prefix + executionId;\n\n// Defensive reads â€” Error Trigger payload shape varies by error type\nconst errorName = errObj.name || errObj.type || '';\nconst errorMessage = String(errObj.message || errObj.description || 'Unknown error');\nconst errorStack = String(errObj.stack || '').substring(0, 500);\n\nconsole.log(`[Run Error Handler] ${workflow.name} execution ${executionId} failed at \"${execution.lastNodeExecuted || '?'}\": ${errorMessage.substring(0, 200)}`);\n\nreturn [{\n  json: {\n    run_id: runId,\n    failed_at: new Date().toISOString(),\n    workflow_name: workflow.name || '',\n    workflow_id: workflow.id || '',\n    execution_id: executionId,\n    execution_url: execution.url || '',\n    last_node: execution.lastNodeExecuted || '',\n    error_name: errorName,\n    error_message: errorMessage,\n    error_stack: errorStack\n  }\n}];"
      },
