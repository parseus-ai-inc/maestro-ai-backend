    {
      "parameters": {
        "jsCode": "// Build Agent Outputs Rows â€” writes verifier + scorer (+ critic on original build)\n// JSON to agent_outputs, keyed by application_run_id + resume_id (version-distinct)\n// so the dashboard can read THIS version's outputs.\n// Critic: present only on the original build (source 'original'); the refine/polish\n// paths have no critic agent run, so critic_output_json stays blank there.\nconst data = $('Set Inputs').first().json.job_result || {};\nconst job = data.job || {};\nconst safeJson = (obj) => (obj && Object.keys(obj).length > 0) ? JSON.stringify(obj) : '';\n\nconst jobId = job.job_id || '';\nconst version = Number(data.resume_row?.version) || 2;\nconst verifierCombined = { resume: data.verifier || null, cover_letter: null };\n\n// Critic JSON only when the critic actually ran (original build). safeJson returns\n// '' for null/empty, so refine/polish (no critic) write blank without a guard, but\n// we gate on source explicitly so a stray critic object can't leak onto a refine row.\nconst isOriginal = data.resume_row?.source === 'original';\nconst criticJson = isOriginal ? safeJson(data.critic) : '';\n\nreturn {\n  json: {\n    url: job.url || '',\n    application_run_id: data.application_run_id || '',\n    resume_id: `${jobId}_v${version}`,\n    job_id: jobId,\n    run_id: data.run_id || '',\n    verifier_output_json: safeJson(verifierCombined),\n    critic_output_json: criticJson,\n    scorer_output_json: safeJson(data.scorer),\n    generated_at: new Date().toISOString()\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -64,
        80
      ],
      "id": "4d8e9fc3-e51f-4f3d-ad09-488380b9ca71",
      "name": "Build Agent Outputs Rows"
    },
    {
      "parameters": {
        "jsCode": "// Build Resume Row â€” writes the resume version to `resumes`.\n// Original build (v1, source 'original') and refine/polish (v2+) both flow through here.\n// resume_id = {job_id}_v{version}. drive_url blank: user saves to Drive from the\n// dashboard, which fills it.\n\nconst jr = $('Set Inputs').first().json.job_result || {};\n\n// Resume content source. The refiner was removed from the orchestrator; the\n// real resume object is jr.resume (carries `markdown` + `success`). Fall back\n// to jr.refiner for any legacy path that still populates it. Field names differ:\n// jr.resume uses `markdown`, the old refiner used `resume_markdown`.\nconst resumeObj = jr.resume || {};\nconst refiner = jr.refiner || {};\nconst resumeMarkdown = resumeObj.markdown || refiner.resume_markdown || '';\nconst resumeTokens = resumeObj.tokens || refiner.tokens || {};\n\n// Record whenever we have resume content. Skip only on explicit failure or no\n// content â€” don't gate on a `success === true` flag, since the v1 build path\n// doesn't always set one. processed_status='error' from a scorer glitch must\n// NOT discard a valid resume.\nif (resumeObj.success === false || !resumeMarkdown) {\n  console.log('[Build Resume Row] no resume markdown / resume failed â€” no resume row.');\n  return [];\n}\nconst jobId = jr.job?.job_id || '';\nif (!jobId) { console.log('[Build Resume Row] No job_id â€” skipping.'); return []; }\n\nconst scorer  = jr.scorer  || {};\nconst verifier = jr.verifier || {};\nconst row = jr.resume_row || {};\nconst version = Number(row.version) || 2;\n\nreturn [{\n  json: {\n    resume_id: `${jobId}_v${version}`,\n    job_id: jobId,\n    application_run_id: jr.application_run_id || '',\n    run_id: jr.run_id || '',\n    url: jr.job?.url || '',\n    company: jr.job?.company || '',\n    title: jr.job?.title || '',\n    version,\n    parent_resume_id: row.parent_resume_id || '',\n    source: row.source || 'refinement',\n    resume_markdown: resumeMarkdown,\n    refinement_instructions: row.refinement_instructions || '',\n    ran_verifier: verifier.ran ? 'TRUE' : 'FALSE',\n    ran_critic: (row.source === 'original' || row.source === 'polish') ? 'TRUE' : 'FALSE',\n    overall_score: (typeof scorer.overall_score === 'number') ? scorer.overall_score : '',\n    recommendation: scorer.recommendation || '',\n    score_delta: (typeof row.score_delta === 'number') ? row.score_delta : '',\n    verifier_verdict: verifier.verdict || '',\n    unsupported_count: (typeof verifier.unsupported_count === 'number') ? verifier.unsupported_count : '',\n    critic_critical_count: (row.source === 'original' && typeof jr.critic?.critical_count === 'number') ? jr.critic.critical_count : '',\n    tokens_in: resumeTokens.input || 0,\n    tokens_out: resumeTokens.output || 0,\n    cost_usd: typeof jr.refinement_cost === 'number' ? jr.refinement_cost : 0,\n    drive_url: '',\n    created_at: new Date().toISOString()\n  }\n}];"
      },
